{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "GDB Launch (Linux)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/simple_gl",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "CMake: build",
      "setupCommands": [
        { "text": "-enable-pretty-printing", "description": "enable pretty printing", "ignoreFailures": true }
      ]
    }
  ]
}